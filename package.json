{
  "name": "resa-capacite",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24 <25",
    "npm": ">=11 <12"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "ci": "npm run lint && npm run format:check && npm test && npm run build",
    "format": "prettier --write \"src/**/*.{js,jsx,css}\" \"tests/**/*.{js,jsx}\" \"index.html\" \"package*.json\" \"vite.config.js\" \"eslint.config.js\" \".prettierrc\" \".github/**/*.yml\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,css}\" \"tests/**/*.{js,jsx}\" \"index.html\" \"package*.json\" \"vite.config.js\" \"eslint.config.js\" \".prettierrc\" \".github/**/*.yml\"",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "prepare": "husky",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "chart.js": "^4.4.0",
    "leaflet": "^1.9.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-leaflet": "^4.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/react": "^14.3.1",
    "@vitejs/plugin-react-oxc": "^0.4.3",
    "@vitest/ui": "^4.1.5",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jsdom": "^25.0.1",
    "lint-staged": "^17.0.4",
    "prettier": "^3.8.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "lint-staged": {
    "*.{js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,json,html,yml,yaml}": [
      "prettier --write"
    ]
  }
}
